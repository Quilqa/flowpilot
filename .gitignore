# Python
__pycache__/
*.pyc
.venv/
venv/

# Node / frontend build
frontend/node_modules/
frontend/dist/

# Runtime artifacts
logs/*.log

# User data: captured templates are screenshots of the user's screen and the
# flows are personal automations — keep them local, track only the folders.
templates/*
!templates/.gitkeep
screenshots/*
!screenshots/.gitkeep
flows/*
!flows/.gitkeep
!flows/demo_ifelse.json
!flows/standard_functions.json

# OS
Thumbs.db
.DS_Store
